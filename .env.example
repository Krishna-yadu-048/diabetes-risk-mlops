# ── MLflow ────────────────────────────────────────────────────────────────────
# Local tracking (default — no setup needed)
# Windows users: run.ps1 sets MLFLOW_TRACKING_URI automatically, no need to change this
MLFLOW_TRACKING_URI=mlruns

# DagsHub tracking (optional — uncomment and fill in to use DagsHub)
# MLFLOW_TRACKING_URI=https://dagshub.com/<your_username>/<your_repo>.mlflow
# MLFLOW_TRACKING_USERNAME=<your_dagshub_username>
# MLFLOW_TRACKING_PASSWORD=<your_dagshub_token>

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_NAME=diabetes-risk-model

# ── Docker Hub (only needed for CD pipeline) ──────────────────────────────────
# DOCKERHUB_USERNAME=<your_dockerhub_username>
# DOCKERHUB_TOKEN=<your_dockerhub_access_token>
